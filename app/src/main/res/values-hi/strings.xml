    <string name="app_description">एक फ़ाइल चुनें और ECDSA P-256 एन्क्रिप्शन का उपयोग करके डिजिटल रूप से हस्ताक्षर करें। हस्ताक्षर मूल फ़ाइल के साथ सहेजा जाएगा।</string>

    <!-- About -->
    <string name="about">ऐप के बारे में</string>
    <string name="about_version">संस्करण %1$s</string>
    <string name="about_description">File Signer आपको ECDSA P-256 क्रिप्टोग्राफ़ी का उपयोग करके अपने डिवाइस पर किसी भी फ़ाइल पर डिजिटल हस्ताक्षर करने देता है। हस्ताक्षर मूल फ़ाइल के साथ सहेजे जाते हैं और फ़ाइल की अखंडता सुनिश्चित करने के लिए किसी भी समय सत्यापित किए जा सकते हैं।</string>
