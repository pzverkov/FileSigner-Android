    <!-- Permission Rationale -->
    <string name="permission_rationale_title">फ़ाइल पहुँच आवश्यक</string>
    <string name="permission_rationale_message">इस ऐप को डिजिटल हस्ताक्षर के लिए दस्तावेज़ चुनने हेतु आपकी फ़ाइलों तक पहुँच चाहिए। आपकी फ़ाइलें आपके डिवाइस पर ही रहती हैं और कहीं अपलोड नहीं की जातीं।</string>
    <string name="permission_rationale_button">पहुँच दें</string>
    <string name="permission_denied_message">फ़ाइल पहुँच अनुमति के बिना, आप हस्ताक्षर के लिए फ़ाइलें नहीं चुन सकते। कृपया सेटिंग्स में अनुमति दें।</string>
    <string name="open_settings">सेटिंग्स खोलें</string>

